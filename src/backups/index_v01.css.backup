@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap');

:root {
  --primary: #c2a98b;
  --bg-lux: #faf9f6;
  --text-main: #1a1a1a;
  --text-dim: #5c5c5c;
  --f-serif: 'Cormorant Garamond', serif;
  --f-sans: 'Plus Jakarta Sans', sans-serif;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: var(--f-sans);
  background: #0d0d0d;
  color: white;
  transition: 0.6s ease;
  overflow-x: hidden;
}

.container-lux {
  max-width: 1500px;
  margin: 0 auto;
  padding: 0 100px;
}

/* --- 🌟 LUXURY PRELOADER --- */
.preloader-3d {
  position: fixed;
  inset: 0;
  background: #0d0d0d;
  z-index: 10000;
  display: flex !important;
  flex-direction: column !important;
  align-items: center;
  justify-content: center;
}

.logo-rotation-3d {
  width: 100px;
  height: 100px;
  border: 2px solid var(--primary);
  border-radius: 50%;
  position: relative;
  transform-style: preserve-3d;
  animation: rota3d 3s linear infinite;
}

@keyframes rota3d {
  0% {
    transform: rotateY(0deg);
  }

  100% {
    transform: rotateY(360deg);
  }
}

/* --- 🕰 LOCAL WIDGET --- */
.local-widget-lux {
  position: fixed;
  bottom: 32px;
  left: 40px;
  z-index: 8000;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(24px);
  padding: 10px 24px;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: white;
  display: flex;
  align-items: center;
  gap: 15px;
  font-size: 11px;
  font-weight: 700;
}

/* --- 🚀 NAVIGATION --- */
.nav-elite {
  position: fixed;
  top: 24px;
  left: 50%;
  transform: translateX(-50%);
  width: 90%;
  max-width: 1400px;
  height: 74px;
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(50px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 100px;
  display: flex !important;
  align-items: center;
  justify-content: space-between;
  padding: 0 40px;
  z-index: 9000;
}

.nav-links-elite {
  display: flex !important;
  gap: 32px !important;
  align-items: center;
}

.nav-link-item {
  text-decoration: none;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  color: white;
  letter-spacing: 2px;
  opacity: 0.6;
  transition: 0.4s;
}

.nav-link-item:hover {
  opacity: 1;
  color: var(--primary);
}

.lux-btn {
  background: var(--primary);
  color: white;
  border: none;
  padding: 12px 30px;
  border-radius: 50px;
  font-weight: 800;
  font-size: 10px;
  letter-spacing: 1px;
  text-transform: uppercase;
  cursor: pointer;
  text-decoration: none;
  transition: 0.4s;
  display: inline-flex;
  align-items: center;
}

.lux-btn:hover {
  background: #b0977a;
  transform: scale(1.05);
}

/* --- 🚀 FIXED SOCIAL SIDEBAR --- */
.social-vertical-fixed {
  position: fixed;
  right: 40px;
  top: 50%;
  transform: translateY(-50%);
  display: flex !important;
  flex-direction: column !important;
  gap: 32px;
  z-index: 8000;
  align-items: center;
  color: white;
}

.social-line {
  width: 1px;
  height: 60px;
  background: rgba(255, 255, 255, 0.1);
}

/* --- HERO --- */
.hero-intareo {
  height: 100vh;
  width: 100%;
  position: relative;
  display: flex;
  align-items: center;
  color: white;
  overflow: hidden;
}

.hero-bg-media {
  position: absolute;
  inset: 0;
  z-index: -3;
  background-image: url("https://silkroad-kokand.uz/img/67782364611c65c5.webp");
  background-size: cover;
  background-position: center;
  filter: brightness(0.25);
}

.hero-overlay-dark {
  position: absolute;
  inset: 0;
  z-index: -2;
  background: linear-gradient(to right, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.3) 100%);
}

.hero-title-intareo {
  font-family: var(--f-serif);
  font-size: 6rem;
  line-height: 1.1;
  letter-spacing: -2px;
  margin-bottom: 25px;
  color: white;
}

/* 🏆 PREMIUM 4 UPGRADES CSS */
.hero-italic-gold {
  font-family: var(--f-serif);
  font-style: italic;
  color: var(--primary);
  font-weight: 300;
}

.play-btn-pulse {
  position: relative;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.play-btn-pulse::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: var(--primary);
  z-index: -1;
  animation: pulse-ring 2.5s infinite cubic-bezier(0.215, 0.61, 0.355, 1);
}

@keyframes pulse-ring {
  0% {
    transform: scale(0.95);
    opacity: 0.8;
  }

  100% {
    transform: scale(2.2);
    opacity: 0;
  }
}

.video-btn-hover:hover {
  background: rgba(255, 255, 255, 0.05);
  border-color: var(--primary) !important;
}

.scroll-indicator-wrap {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15px;
  z-index: 20;
}

.scroll-text {
  font-size: 9px;
  letter-spacing: 5px;
  color: white;
  opacity: 0.4;
  text-transform: uppercase;
  writing-mode: vertical-rl;
  transform: rotate(180deg);
}

.scroll-line-container {
  width: 1px;
  height: 100px;
  background: rgba(255, 255, 255, 0.1);
  position: relative;
  overflow: hidden;
}

.scroll-line-fill {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 50%;
  background: var(--primary);
  animation: scroll-drop 2.5s infinite ease-in-out;
}

@keyframes scroll-drop {
  0% {
    transform: translateY(-100%);
    opacity: 0;
  }

  25% {
    opacity: 1;
  }

  75% {
    opacity: 1;
  }

  100% {
    transform: translateY(200%);
    opacity: 0;
  }
}

.glass-stats-panel {
  display: inline-flex;
  gap: 40px;
  align-items: center;
  background: rgba(25, 25, 25, 0.4);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  padding: 24px 45px;
  border-radius: 20px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 30px 60px rgba(0, 0, 0, 0.3);
}

/* 🖼️ THE IMAGE MASTERPIECE CSS */
.hero-image-block {
  width: 100%;
  height: 650px;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.08);
  position: relative;
  z-index: 5;
}

.hero-image-block img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.hero-image-block:hover img {
  transform: scale(1.05);
}

.hero-image-vignette {
  position: absolute;
  inset: 0;
  box-shadow: inset 0 0 100px rgba(0, 0, 0, 0.6);
  pointer-events: none;
  z-index: 2;
}

.hero-image-wireframe {
  position: absolute;
  inset: -20px;
  border: 1px solid rgba(194, 169, 139, 0.4);
  border-radius: 34px;
  pointer-events: none;
  z-index: 0;
}

/* 🔥 3D DYNAMIC WIREFRAME ACCENTS */
.orbital-dot {
  position: absolute;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 0 15px 4px var(--primary), 0 0 30px 10px rgba(194, 169, 139, 0.6);
  z-index: 10;
  animation: orbit-path 12s linear infinite;
}

@keyframes orbit-path {
  0% {
    top: 0;
    left: 0;
  }

  25% {
    top: 0;
    left: calc(100% - 6px);
  }

  50% {
    top: calc(100% - 6px);
    left: calc(100% - 6px);
  }

  75% {
    top: calc(100% - 6px);
    left: 0;
  }

  100% {
    top: 0;
    left: 0;
  }
}

.corner-node {
  position: absolute;
  width: 12px;
  height: 12px;
  border: 1px solid var(--primary);
  background: rgba(194, 169, 139, 0.15);
  backdrop-filter: blur(4px);
  transform: rotate(45deg);
  animation: node-pulse 3s infinite alternate ease-in-out;
  z-index: 5;
}

.corner-tl {
  top: -6px;
  left: -6px;
}

.corner-tr {
  top: -6px;
  right: -6px;
}

.corner-bl {
  bottom: -6px;
  left: -6px;
}

.corner-br {
  bottom: -6px;
  right: -6px;
}

@keyframes node-pulse {
  0% {
    transform: rotate(45deg) scale(0.9);
    box-shadow: 0 0 0px transparent;
  }

  100% {
    transform: rotate(45deg) scale(1.4);
    box-shadow: 0 0 15px var(--primary);
  }
}

/* 🔥 END DYNAMIC ACCENTS */


/* --- 🏨 ROOMS --- */
.booking-section {
  padding: 180px 0;
  background: white;
  color: #1a1a1a;
  border-radius: 80px 80px 0 0;
}

.booking-card-wrapper {
  background: #fcfaf6;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid #eee;
  transition: 0.4s;
}

.booking-card-wrapper:hover {
  transform: translateY(-10px);
  box-shadow: 0 40px 80px rgba(0, 0, 0, 0.1);
}

.booking-img-container {
  height: 260px;
  overflow: hidden;
  position: relative;
}

.booking-img-container img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: 0.6s;
}

.booking-card-wrapper:hover .booking-img-container img {
  transform: scale(1.08);
}

.booking-content {
  padding: 30px;
}

.booking-room-type {
  font-size: 1.3rem;
  font-weight: 800;
  color: #c2a98b;
  margin-bottom: 12px;
  text-transform: uppercase;
}

.price-main {
  font-size: 2.2rem;
  font-weight: 800;
  color: #1a1a1a;
  margin-bottom: 20px;
}

.booking-cta-full {
  width: 100%;
  background: #c2a98b;
  color: white;
  padding: 20px;
  border-radius: 12px;
  border: none;
  font-weight: 800;
  text-transform: uppercase;
  cursor: pointer;
  transition: 0.3s;
}

.booking-cta-full:hover {
  background: #ad9376;
}

@media (max-width: 1200px) {

  .hero-image-block,
  .hero-image-wireframe,
  .hero-image-badge {
    display: none;
  }

  .hero-title-intareo {
    font-size: 10vw;
  }
}
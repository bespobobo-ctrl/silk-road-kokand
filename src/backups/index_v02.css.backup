@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap');

:root {
  --primary: #c2a98b;
  --bg-lux: #faf9f6;
  --text-main: #1a1a1a;
  --text-dim: #5c5c5c;
  --f-serif: 'Cormorant Garamond', serif;
  --f-sans: 'Plus Jakarta Sans', sans-serif;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

html {
  scroll-behavior: smooth;
}

html.lenis,
html.lenis body {
  height: auto;
}

.lenis.lenis-smooth {
  scroll-behavior: auto !important;
}

.lenis.lenis-smooth [data-lenis-prevent] {
  overscroll-behavior: contain;
}

.lenis.lenis-stopped {
  overflow: hidden;
}

.lenis.lenis-scrolling iframe {
  pointer-events: none;
}

body {
  font-family: var(--f-sans);
  background: #0d0d0d;
  color: white;
  transition: 0.6s ease;
  overflow-x: hidden;
}

/* рџЊџ MAGNETIC TRAILING CURSOR (NO BLUR, NO LAG) */
.cursor-aura {
  position: fixed;
  top: 0;
  left: 0;
  width: 46px;
  height: 46px;
  border-radius: 50%;
  border: 1.5px solid rgba(194, 169, 139, 0.6);
  pointer-events: none;
  z-index: 99999;
  transform: translate(-50%, -50%);
  transition: width 0.3s, height 0.3s;
}

.cursor-aura.active-hover {
  width: 60px;
  height: 60px;
  background: rgba(194, 169, 139, 0.05);
}

.container-lux {
  max-width: 1500px;
  margin: 0 auto;
  padding: 0 100px;
}

/* --- рџЊџ LUXURY PRELOADER --- */
.preloader-3d {
  position: fixed;
  inset: 0;
  background: #0d0d0d;
  z-index: 10000;
  display: flex !important;
  flex-direction: column !important;
  align-items: center;
  justify-content: center;
}

.logo-rotation-3d {
  width: 100px;
  height: 100px;
  border: 2px solid var(--primary);
  border-radius: 50%;
  position: relative;
  transform-style: preserve-3d;
  animation: rota3d 3s linear infinite;
}

@keyframes rota3d {
  0% {
    transform: rotateY(0deg);
  }

  100% {
    transform: rotateY(360deg);
  }
}

/* --- рџ•° LOCAL WIDGET & AMBIENT SOUND --- */
.local-widget-lux {
  position: fixed;
  bottom: 32px;
  left: 40px;
  z-index: 8000;
  background: rgba(25, 25, 25, 0.4);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  padding: 10px 24px;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: white;
  display: flex;
  align-items: center;
  gap: 15px;
  font-size: 11px;
  font-weight: 700;
}

.ambient-toggle {
  display: flex;
  align-items: center;
  gap: 10px;
  opacity: 0.5;
  transition: 0.3s;
  cursor: pointer;
}

.ambient-toggle:hover {
  opacity: 1;
  color: var(--primary);
}

.sound-bars {
  display: flex;
  gap: 3px;
  height: 14px;
  align-items: flex-end;
}

.sound-bar {
  width: 2px;
  background: currentColor;
  border-radius: 2px;
  transition: height 0.3s ease;
}

.playing .sound-bar {
  animation: eq-bounce 1s infinite alternate ease-in-out;
}

.playing .sound-bar:nth-child(2) {
  animation-delay: 0.2s;
}

.playing .sound-bar:nth-child(3) {
  animation-delay: 0.4s;
}

.playing .sound-bar:nth-child(4) {
  animation-delay: 0.1s;
}

@keyframes eq-bounce {
  0% {
    height: 4px;
  }

  100% {
    height: 14px;
  }
}

/* --- рџљЂ NAVIGATION --- */
.nav-elite {
  position: fixed;
  top: 24px;
  left: 50%;
  transform: translateX(-50%);
  width: 90%;
  max-width: 1400px;
  height: 74px;
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(50px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 100px;
  display: flex !important;
  align-items: center;
  justify-content: space-between;
  padding: 0 40px;
  z-index: 9000;
}

.nav-links-elite {
  display: flex !important;
  gap: 32px !important;
  align-items: center;
}

.nav-link-item {
  text-decoration: none;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  color: white;
  letter-spacing: 2px;
  opacity: 0.6;
  transition: 0.4s;
}

.nav-link-item:hover {
  opacity: 1;
  color: var(--primary);
}

.lux-btn {
  background: var(--primary);
  color: white;
  border: none;
  padding: 12px 30px;
  border-radius: 50px;
  font-weight: 800;
  font-size: 10px;
  letter-spacing: 1px;
  text-transform: uppercase;
  text-decoration: none;
  transition: 0.4s;
  display: inline-flex;
  align-items: center;
  cursor: pointer;
}

.lux-btn:hover {
  background: #b0977a;
  transform: scale(1.05);
}

/* --- рџљЂ FIXED SOCIAL SIDEBAR --- */
.social-vertical-fixed {
  position: fixed;
  right: 40px;
  top: 50%;
  transform: translateY(-50%);
  display: flex !important;
  flex-direction: column !important;
  gap: 32px;
  z-index: 8000;
  align-items: center;
  color: white;
}

.social-line {
  width: 1px;
  height: 60px;
  background: rgba(255, 255, 255, 0.1);
}

/* --- HERO --- */
.hero-intareo {
  height: 100vh;
  width: 100%;
  position: relative;
  display: flex;
  align-items: center;
  color: white;
  overflow: hidden;
}

.hero-overlay-dark {
  position: absolute;
  inset: 0;
  z-index: -2;
  background: linear-gradient(to right, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.3) 100%);
}

.hero-title-intareo {
  font-family: var(--f-serif);
  font-size: 6rem;
  line-height: 1.1;
  letter-spacing: -2px;
  margin-bottom: 25px;
  color: white;
}

.hero-italic-gold {
  font-family: var(--f-serif);
  font-style: italic;
  color: var(--primary);
  font-weight: 300;
}

.play-btn-pulse {
  position: relative;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.play-btn-pulse::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: var(--primary);
  z-index: -1;
  animation: pulse-ring 2.5s infinite cubic-bezier(0.215, 0.61, 0.355, 1);
}

@keyframes pulse-ring {
  0% {
    transform: scale(0.95);
    opacity: 0.8;
  }

  100% {
    transform: scale(2.2);
    opacity: 0;
  }
}

.video-btn-hover:hover {
  background: rgba(255, 255, 255, 0.05);
  border-color: var(--primary) !important;
}

.scroll-indicator-wrap {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15px;
  z-index: 20;
}

.scroll-text {
  font-size: 9px;
  letter-spacing: 5px;
  color: white;
  opacity: 0.4;
  text-transform: uppercase;
  writing-mode: vertical-rl;
  transform: rotate(180deg);
}

.scroll-line-container {
  width: 1px;
  height: 100px;
  background: rgba(255, 255, 255, 0.1);
  position: relative;
  overflow: hidden;
}

.scroll-line-fill {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 50%;
  background: var(--primary);
  animation: scroll-drop 2.5s infinite ease-in-out;
}

@keyframes scroll-drop {
  0% {
    transform: translateY(-100%);
    opacity: 0;
  }

  25% {
    opacity: 1;
  }

  75% {
    opacity: 1;
  }

  100% {
    transform: translateY(200%);
    opacity: 0;
  }
}

.glass-stats-panel {
  display: inline-flex;
  gap: 40px;
  align-items: center;
  background: rgba(25, 25, 25, 0.4);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  padding: 24px 45px;
  border-radius: 20px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 30px 60px rgba(0, 0, 0, 0.3);
}

.hero-image-block {
  width: 100%;
  height: 650px;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.08);
  position: relative;
  z-index: 5;
}

.hero-image-vignette {
  position: absolute;
  inset: 0;
  box-shadow: inset 0 0 100px rgba(0, 0, 0, 0.6);
  pointer-events: none;
  z-index: 2;
}

.hero-image-wireframe {
  position: absolute;
  inset: -20px;
  border: 1px solid rgba(194, 169, 139, 0.4);
  border-radius: 34px;
  pointer-events: none;
  z-index: 0;
}

.hero-slider-nav {
  position: absolute;
  bottom: 25px;
  right: 25px;
  display: flex;
  gap: 10px;
  z-index: 20;
}

.hero-nav-dot {
  width: 20px;
  height: 3px;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4px;
  transition: 0.4s ease;
  cursor: pointer;
}

.hero-nav-dot:hover {
  background: rgba(255, 255, 255, 0.8);
}

.hero-nav-dot.active {
  background: var(--primary);
  width: 40px;
  box-shadow: 0 0 10px rgba(194, 169, 139, 0.6);
}

.orbital-dot {
  position: absolute;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 0 15px 4px var(--primary), 0 0 30px 10px rgba(194, 169, 139, 0.6);
  z-index: 10;
  animation: orbit-path 12s linear infinite;
}

@keyframes orbit-path {
  0% {
    top: 0;
    left: 0;
  }

  25% {
    top: 0;
    left: calc(100% - 6px);
  }

  50% {
    top: calc(100% - 6px);
    left: calc(100% - 6px);
  }

  75% {
    top: calc(100% - 6px);
    left: 0;
  }

  100% {
    top: 0;
    left: 0;
  }
}

.corner-node {
  position: absolute;
  width: 12px;
  height: 12px;
  border: 1px solid var(--primary);
  background: rgba(194, 169, 139, 0.15);
  backdrop-filter: blur(4px);
  transform: rotate(45deg);
  animation: node-pulse 3s infinite alternate ease-in-out;
  z-index: 5;
}

.corner-tl {
  top: -6px;
  left: -6px;
}

.corner-tr {
  top: -6px;
  right: -6px;
}

.corner-bl {
  bottom: -6px;
  left: -6px;
}

.corner-br {
  bottom: -6px;
  right: -6px;
}

@keyframes node-pulse {
  0% {
    transform: rotate(45deg) scale(0.9);
    box-shadow: 0 0 0px transparent;
  }

  100% {
    transform: rotate(45deg) scale(1.4);
    box-shadow: 0 0 15px var(--primary);
  }
}

/* --- рџЏЁ ROOMS (SPACING ADJUSTED) --- */
.booking-section {
  padding: 100px 0;
  background: white;
  color: #1a1a1a;
  border-radius: 80px 80px 0 0;
  position: relative;
  overflow: hidden;
}

/* рџ”Ґ LUXURY ROOM SPEC CARDS (INTERACTIVE GRID) */
.room-spec-card {
  border-top: 1px solid rgba(0, 0, 0, 0.08);
  /* Natural fine line separator */
  padding: 24px 20px 24px 0;
  /* Space for the text */
  transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  position: relative;
  cursor: pointer;
  border-radius: 4px;
}

.room-spec-card:hover {
  background: rgba(194, 169, 139, 0.04);
  /* Ultra light luxurious gold tint */
  border-top-color: var(--primary);
  /* Highlight the dividing line */
  padding-left: 20px;
  /* Text slides to the right elegantly */
}

.room-spec-card .arrow-icon {
  position: absolute;
  right: 20px;
  top: 50%;
  transform: translateY(-50%) translateX(-20px);
  opacity: 0;
  transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
  color: var(--primary);
  font-size: 1.2rem;
}

.room-spec-card:hover .arrow-icon {
  opacity: 1;
  transform: translateY(-50%) translateX(0);
  /* Arrow shoots in from left */
}

/* END INTERACTIVE GRID */

/* рџ’Ћ LUXURIOUS BORDERLESS CARDS */
.booking-card-wrapper {
  background: white;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(194, 169, 139, 0.08);
  /* Replaced ugly gray #eee border with ultra-faint gold */
  box-shadow: 0 15px 45px rgba(0, 0, 0, 0.02);
  /* Delicate global drop shadow */
  transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
  position: relative;
}

.booking-card-wrapper:hover {
  transform: translateY(-16px);
  box-shadow: 0 40px 80px rgba(194, 169, 139, 0.12);
  /* Warmer, softer luxury shadow */
  border-color: rgba(194, 169, 139, 0.4);
}

.booking-img-container {
  height: 260px;
  overflow: hidden;
  position: relative;
}

.booking-img-container img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
}

.booking-card-wrapper:hover .booking-img-container img {
  transform: scale(1.12);
}

.booking-content {
  padding: 30px;
}

.booking-room-type {
  font-size: 1.3rem;
  font-weight: 800;
  color: #c2a98b;
  margin-bottom: 12px;
  text-transform: uppercase;
}

.price-main {
  font-size: 2.2rem;
  font-weight: 800;
  color: #1a1a1a;
  margin-bottom: 20px;
}

.booking-cta-full {
  width: 100%;
  background: #c2a98b;
  color: white;
  padding: 20px;
  border-radius: 12px;
  border: none;
  font-weight: 800;
  text-transform: uppercase;
  transition: 0.3s;
  cursor: pointer;
}

.booking-cta-full:hover {
  background: #ad9376;
}

/* рџЊџ ROOM CARD AMENITIES & SLIDER */
.card-amenity-icons {
  position: absolute;
  top: 15px;
  left: 15px;
  display: flex;
  gap: 10px;
  z-index: 10;
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(10px);
  padding: 6px 12px;
  border-radius: 30px;
  color: #1a1a1a;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.card-slider-bars {
  position: absolute;
  bottom: 15px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 8px;
  z-index: 10;
}

.card-slider-bar {
  width: 30px;
  height: 3px;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4px;
  cursor: pointer;
  transition: 0.3s;
}

.card-slider-bar.active {
  background: white;
  width: 45px;
}

.editorial-card-num {
  position: absolute;
  top: 15px;
  right: 15px;
  color: white;
  font-family: var(--f-serif);
  font-size: 1.4rem;
  font-weight: 600;
  z-index: 5;
  padding: 4px 14px;
  background: rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 30px;
}

/* рџ”¦ LIGHTBOX & VR MODALS */
.lightbox-modal,
.vr-modal {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.95);
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(15px);
}

.lightbox-nav-container {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  position: relative;
}

.lightbox-modal img {
  max-width: 80%;
  max-height: 80vh;
  border-radius: 12px;
  box-shadow: 0 50px 100px rgba(0, 0, 0, 0.8);
  pointer-events: none;
}

.nav-btn-lux {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: white;
  width: 60px;
  height: 60px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: 0.3s;
  z-index: 10005;
}

.nav-btn-lux:hover {
  background: var(--primary);
  transform: scale(1.1);
}

.nav-btn-lux.left {
  position: absolute;
  left: 40px;
}

.nav-btn-lux.right {
  position: absolute;
  right: 40px;
}

.lightbox-counter {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  color: white;
  font-family: var(--f-serif);
  font-size: 1.2rem;
  letter-spacing: 4px;
  opacity: 0.6;
}

.close-lightbox,
.close-vr {
  position: absolute;
  top: 40px;
  right: 40px;
  background: none;
  border: none;
  color: white;
  cursor: pointer;
  opacity: 0.6;
  transition: 0.3s;
  z-index: 10010;
}

.close-lightbox:hover,
.close-vr:hover {
  opacity: 1;
  transform: rotate(90deg);
}

.vr-container {
  width: 90vw;
  height: 85vh;
  background: #000;
  border-radius: 20px;
  overflow: hidden;
  position: relative;
  box-shadow: 0 50px 100px rgba(0, 0, 0, 0.8);
}

.cinematic-tour {
  background: #000;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.panorama-overflow {
  width: 100%;
  height: 100%;
  overflow: hidden;
  position: relative;
}

.panorama-strips {
  height: 100%;
  display: flex;
  align-items: center;
  position: absolute;
  left: 0;
  transform-style: preserve-3d;
}

.cinematic-img {
  height: 110%;
  min-width: 250vw;
  object-fit: cover;
  filter: brightness(0.8) contrast(1.1);
  user-select: none;
  pointer-events: none;
}

.vr-notice {
  position: absolute;
  bottom: 50px;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
  color: white;
  z-index: 10;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(15px);
  padding: 15px 40px;
  border-radius: 50px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  pointer-events: none;
}

.vr-notice span {
  letter-spacing: 5px;
  font-size: 10px;
  opacity: 0.6;
}

.vr-notice p {
  margin-top: 5px;
  font-size: 14px;
  font-weight: 300;
}

#services {
  background: #0d0d0d !important;
  border-top: 1px solid rgba(194, 169, 139, 0.1);
  padding-bottom: 80px;
}

.service-card-premium {
  position: relative;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  padding: 60px 40px;
  border-radius: 30px;
  overflow: hidden;
  text-align: center;
  transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
  backdrop-filter: blur(10px);
}

.service-card-premium:hover {
  background: rgba(194, 169, 139, 0.05);
  border-color: rgba(194, 169, 139, 0.3);
  box-shadow: 0 40px 80px rgba(0, 0, 0, 0.6);
}

.service-icon-wrap {
  width: 80px;
  height: 80px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30px;
  color: var(--primary);
  transition: 0.5s;
}

.service-card-premium:hover .service-icon-wrap {
  background: var(--primary);
  color: white;
  transform: scale(1.1) rotate(10deg);
}

.service-card-title {
  color: white;
  font-family: var(--f-serif);
  font-size: 1.8rem;
  margin-bottom: 20px;
  letter-spacing: 1px;
}

.service-card-desc {
  color: var(--text-dim);
  line-height: 1.8;
  font-size: 1rem;
  font-weight: 300;
}

.service-card-bg-gradient {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top right, rgba(194, 169, 139, 0.1), transparent 70%);
  opacity: 0;
  transition: 0.5s;
}

.service-card-premium:hover .service-card-bg-gradient {
  opacity: 1;
}

.service-bg-glow {
  position: absolute;
  bottom: -20%;
  right: -10%;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(194, 169, 139, 0.08), transparent 70%);
  filter: blur(80px);
  pointer-events: none;
}

.service-card-premium {
  padding: 80px 40px !important;
}

.service-hover-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 120%, rgba(194, 169, 139, 0.15), transparent 70%);
  opacity: 0;
  transition: 0.6s ease;
}

.service-card-premium:hover .service-hover-glow {
  opacity: 1;
}

.service-border-bottom {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 2px;
  background: var(--primary);
  transition: 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
}

.service-card-premium:hover .service-border-bottom {
  width: 100%;
}

.service-bg-text-watermark {
  position: absolute;
  bottom: 0;
  right: -5%;
  font-size: 15vw;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.015);
  font-family: var(--f-sans);
  letter-spacing: 50px;
  pointer-events: none;
  z-index: 0;
  user-select: none;
}

/* SERVICES BG & COMPACT */
#services {
  background: url('https://silkroad-kokand.uz/img/67782364611c65c5.webp') no-repeat center center !important;
  background-size: cover !important;
  background-attachment: fixed !important;
  padding: 80px 0 160px 0 !important;
}

.services-bg-image-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, #0d0d0d, rgba(13, 13, 13, 0.85), #0d0d0d);
  z-index: 1;
}

.service-bg-text-watermark.centered {
  top: 50%;
  left: 50%;
  right: auto;
  bottom: auto;
  transform: translate(-50%, -50%);
  font-size: 20vw;
  text-align: center;
  width: 100%;
}

.service-card-premium {
  padding: 40px 30px !important;
  background: rgba(255, 255, 255, 0.05);
}

/* HORIZONTAL SLIDER SYSTEM */
.horizontal-lux-container {
  display: flex !important;
  overflow-x: auto !important;
  scroll-snap-type: x mandatory !important;
  background: #0d0d0d;
  scrollbar-width: none;
}

.horizontal-lux-container::-webkit-scrollbar {
  display: none;
}

.horizontal-slide {
  flex-shrink: 0 !important;
  width: 100vw !important;
  min-height: 100vh !important;
  position: relative;
  scroll-snap-align: start;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80px 0;
  overflow: hidden;
}

.slide-bg-wrap {
  position: absolute;
  inset: 0;
  z-index: 0;
  background: url('https://silkroad-kokand.uz/img/67782364611c65c5.webp') center center no-repeat;
  background-size: cover;
  background-attachment: fixed;
}

.slide-bg-wrap.conference {
  background-image: url('https://silkroad-kokand.uz/img/caae39234b600613.webp') !important;
}

/* CONFERENCE STYLES */
.modern-split-info {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 100px;
  align-items: center;
  width: 100%;
}

.lux-label {
  font-size: 11px;
  letter-spacing: 8px;
  color: var(--primary);
  font-weight: 800;
  margin-bottom: 20px;
  display: block;
  text-transform: uppercase;
}

.title-serif-huge {
  font-size: 5rem;
  font-family: var(--f-serif);
  color: white;
  line-height: 1.1;
  margin-bottom: 30px;
}

.p-desc-lux {
  font-size: 1.15rem;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.8;
  margin-bottom: 50px;
}

.conf-stats-elite {
  display: flex;
  gap: 40px;
  margin-bottom: 60px;
}

.conf-stat-item .num {
  font-size: 2.2rem;
  font-weight: 900;
  color: var(--primary);
  margin-bottom: 5px;
}

.conf-stat-item .label {
  font-size: 9px;
  letter-spacing: 2px;
  opacity: 0.6;
  text-transform: uppercase;
}

.book-conf-btn {
  background: var(--primary);
  color: white;
  padding: 20px 45px;
  border-radius: 50px;
  border: none;
  display: flex;
  align-items: center;
  gap: 15px;
  font-weight: 800;
  font-size: 11px;
  letter-spacing: 2px;
  cursor: pointer;
  transition: 0.4s;
}

.book-conf-btn:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 30px rgba(194, 169, 139, 0.4);
}

.conference-visual-side {
  position: relative;
}

.conf-img-frame {
  position: relative;
  width: 100%;
  aspect-ratio: 16/10;
  overflow: hidden;
  border-radius: 4px;
}

.conf-img-frame img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.lux-border-overlay {
  position: absolute;
  inset: 20px;
  border: 1px solid rgba(194, 169, 139, 0.3);
  pointer-events: none;
}

/* HORIZONTAL NAVIGATION UI */
.horizontal-nav-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 50;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.nav-btn-round {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(194, 169, 139, 0.3);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  pointer-events: auto;
  transition: 0.4s;
}

.nav-btn-round:hover {
  background: var(--primary);
  border-color: var(--primary);
  box-shadow: 0 0 20px rgba(194, 169, 139, 0.4);
}

.nav-btn-round.disabled {
  opacity: 0.2;
  cursor: not-allowed;
  pointer-events: none;
}

.nav-btn-round.left {
  left: 40px;
}

.nav-btn-round.right {
  right: 40px;
}

.slide-pagination-dots {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 15px;
  pointer-events: auto;
}

.dot-item {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  cursor: pointer;
  transition: 0.4s;
}

.dot-item.active {
  background: var(--primary);
  transform: scale(1.5);
  box-shadow: 0 0 10px var(--primary);
}

.swipe-hint-label {
  position: absolute;
  bottom: 80px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  font-size: 10px;
  letter-spacing: 2px;
  font-weight: 800;
}

.hint-line {
  width: 1px;
  height: 30px;
  background: var(--primary);
  opacity: 0.4;
}

/* LOCAL SERVICES SLIDER BUTTONS */
.slide-next-btn-internal,
.slide-prev-btn-internal {
  background: white;
  color: #1a1a1a;
  padding: 15px 30px;
  border-radius: 50px;
  border: none;
  display: flex !important;
  align-items: center;
  gap: 15px;
  font-weight: 800;
  font-size: 11px;
  letter-spacing: 2px;
  cursor: pointer;
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 100;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
  pointer-events: auto;
  transition: 0.4s ease;
}

.slide-next-btn-internal {
  right: 40px;
}

.slide-prev-btn-internal {
  left: 40px;
}

.slide-next-btn-internal:hover {
  background: var(--primary);
  color: white;
  transform: translate(10px, -50%);
}

.slide-prev-btn-internal:hover {
  background: var(--primary);
  color: white;
  transform: translate(-10px, -50%);
}

.services-pagination-local {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 15px;
  z-index: 100;
  pointer-events: auto;
}

.services-pagination-local .dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  cursor: pointer;
  transition: 0.4s;
}

.services-pagination-local .dot.active {
  background: var(--primary);
  transform: scale(1.4);
  box-shadow: 0 0 15px var(--primary);
}

/* CENTERED FOOTER NAV FOR SERVICES/CONF */
.slide-footer-centered {
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  gap: 20px !important;
  margin-top: 40px !important;
  width: 100% !important;
}

.slide-next-btn-internal.center,
.slide-prev-btn-internal.center {
  position: relative !important;
  top: auto !important;
  right: auto !important;
  left: auto !important;
  transform: none !important;
  margin: 0 auto !important;
  min-width: 280px !important;
  justify-content: center !important;
}

.services-pagination-local.integrated {
  position: relative !important;
  bottom: auto !important;
  left: auto !important;
  transform: none !important;
}

/* CONFERENCE IMAGE CAROUSEL DOTS */
.conf-carousel-dots {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin-top: 15px;
}

.conf-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  cursor: pointer;
  transition: 0.4s;
}

.conf-dot.active {
  background: var(--primary);
  transform: scale(1.4);
  box-shadow: 0 0 10px var(--primary);
}

/* RESTAURANT SECTION */
.restaurant-section {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 120px 0;
  overflow: hidden;
}

.restaurant-bg-img {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
}

.restaurant-bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(13, 13, 13, 0.95), rgba(13, 13, 13, 0.8));
}

.restaurant-split {
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: 80px;
  align-items: center;
}

.restaurant-img-main {
  position: relative;
  width: 100%;
  aspect-ratio: 4/3;
  overflow: hidden;
  border-radius: 6px;
}

.rest-nav-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.3);
  background: rgba(0, 0, 0, 0.5);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: 0.3s;
  z-index: 10;
}

.rest-nav-btn:hover {
  background: var(--primary);
  border-color: var(--primary);
}

.rest-nav-btn.left {
  left: 15px;
}

.rest-nav-btn.right {
  right: 15px;
}

.rest-img-counter {
  position: absolute;
  bottom: 15px;
  right: 15px;
  background: rgba(0, 0, 0, 0.6);
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1px;
  color: var(--primary);
  z-index: 10;
}

.rest-thumbs {
  display: flex;
  gap: 8px;
  margin-top: 15px;
}

.rest-thumb {
  width: 70px;
  height: 50px;
  border-radius: 4px;
  overflow: hidden;
  cursor: pointer;
  opacity: 0.4;
  border: 2px solid transparent;
  transition: 0.3s;
}

.rest-thumb.active {
  opacity: 1;
  border-color: var(--primary);
}

.rest-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.rest-features {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-top: 40px;
}

.rest-feature {
  display: flex;
  align-items: flex-start;
  gap: 15px;
}

.rest-feature strong {
  display: block;
  font-size: 14px;
  color: white;
  margin-bottom: 2px;
}

.rest-feature span {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.5);
}

/* RESTAURANT ZOOM BUTTON */
.rest-zoom-btn {
  position: absolute;
  top: 15px;
  left: 15px;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 10;
  transition: 0.3s;
  border: 1px solid rgba(255, 255, 255, 0.15);
}

.rest-zoom-btn:hover {
  background: var(--primary);
  border-color: var(--primary);
  transform: scale(1.1);
}

.lux-label {
  font-size: 11px;
  letter-spacing: 6px;
  color: var(--primary);
  font-weight: 800;
  display: block;
  margin-bottom: 15px;
}

/* CONTACT SECTION */
.contact-section {
  padding: 120px 0;
  background: var(--bg-dark);
  color: white;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
}

.contact-info-col {
  display: flex;
  flex-direction: column;
  gap: 40px;
}

.contact-item {
  display: flex;
  align-items: flex-start;
  gap: 20px;
}

.contact-icon {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: rgba(194, 169, 139, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  flex-shrink: 0;
}

.contact-subtitle {
  font-family: var(--f-serif);
  font-size: 1.2rem;
  color: var(--primary);
  margin-bottom: 10px;
}

.contact-text {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
  margin-bottom: 8px;
}

.contact-gps {
  display: flex;
  flex-direction: column;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.4);
}

.contact-link {
  display: block;
  color: white;
  text-decoration: none;
  font-size: 16px;
  margin-bottom: 8px;
  transition: 0.3s;
}

.contact-link:hover {
  color: var(--primary);
}

.contact-link.highlight {
  color: var(--primary);
}

.contact-sub {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.4);
  margin-left: 5px;
}

.contact-socials-wrapper {
  margin-top: 10px;
  padding-top: 40px;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.contact-socials {
  display: flex;
  gap: 15px;
  margin-top: 15px;
}

.contact-social-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  border-radius: 30px;
  background: rgba(255, 255, 255, 0.05);
  color: white;
  text-decoration: none;
  font-size: 14px;
  transition: 0.3s;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.contact-social-btn:hover {
  background: var(--primary);
  color: #0d0d0d;
  border-color: var(--primary);
}

.contact-map-col {
  height: 100%;
}

.map-placeholder {
  width: 100%;
  height: 100%;
  min-height: 400px;
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.map-bg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: grayscale(100%) contrast(1.2) brightness(0.7);
}

.map-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(13, 13, 13, 0.9), transparent);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 40px;
}

.contact-desc {
  font-size: 16px;
  color: white;
  line-height: 1.6;
  margin-bottom: 25px;
  max-width: 80%;
  font-style: italic;
  font-family: var(--f-serif);
}

/* BOOKING MODAL (2026 Premium Edition) */
.booking-modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px;
}

.booking-modal-bg-blur {
  position: absolute;
  inset: 0;
  background: rgba(10, 10, 10, 0.85);
  backdrop-filter: blur(25px);
  -webkit-backdrop-filter: blur(25px);
}

.booking-modal-content {
  position: relative;
  z-index: 100000;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 40px 100px rgba(0, 0, 0, 0.8);
  border-radius: 20px;
  width: 100%;
  max-width: 1200px;
  height: 90vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.booking-modal-header {
  padding: 30px 40px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  background: rgba(0, 0, 0, 0.2);
  text-align: center;
}

.booking-iframe-container {
  flex: 1;
  width: 100%;
  background: #fff;
  /* Exely requires white background normally */
}

.close-booking-btn {
  position: absolute;
  top: 25px;
  right: 25px;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: white;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: 0.3s;
  z-index: 10;
}

.close-booking-btn:hover {
  background: var(--primary);
  color: black;
  transform: rotate(90deg);
}

@media (max-width: 768px) {
  .booking-modal-overlay {
    padding: 0;
  }

  .booking-modal-content {
    height: 100vh;
    border-radius: 0;
    max-width: 100%;
    border: none;
  }

  .close-booking-btn {
    top: 15px;
    right: 15px;
    width: 40px;
    height: 40px;
  }

  .booking-modal-header {
    padding: 20px;
  }
}